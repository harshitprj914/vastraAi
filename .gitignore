# ==========================================
# VastraAI Project - Root .gitignore
# ==========================================

# ── Next.js / Frontend ──────────────────
.next/
dist/
build/
out/

# ── Node.js ─────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python / Backend ────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
*.so
.Python

# ── Environment & Secrets ───────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# ── OS / Editor ─────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Misc ────────────────────────────────
*.log
*.tmp
*.bak
.cache/
coverage/
.nyc_output/
